# ==============================================================================
# Docker Compose Environment Configuration Template (Example)
# Copy this to .env (or keep as docker.env and load via docker-compose)
# ==============================================================================

# Database Connection (Spring Boot & PostgreSQL Container)
DB_HOST=db
DB_PORT=5432
DB_NAME=filmdb
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# PostgreSQL Initial Configuration
POSTGRES_DB=filmdb
POSTGRES_USER=your_db_username
POSTGRES_PASSWORD=your_db_password

# JWT Configuration
JWT_SECRET=your_base64_jwt_secret_key_here
JWT_EXPIRATION=100000
REFRESH_TOKEN_EXPIRATION=604800000

# TMDB Bearer Token (Optional, for movie images/details fetch)
TMDB_BEARER_TOKEN=your_tmdb_bearer_token_here

# Frontend Configuration
# NEXT_PUBLIC_API_URL maps relative API requests in client components
NEXT_PUBLIC_API_URL=http://localhost:8080
# INTERNAL_API_URL maps internal Next.js node server API rewrites to the backend container
INTERNAL_API_URL=http://backend:8080
NGROK_AUTHTOKEN=your_ngrok_authtoken_here
